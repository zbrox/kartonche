    "While Using App" : {
      "comment" : "Location permission status: only while app is open",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Докато използвате приложението"
          }
        }
      }
    },
    "Widgets work when app is closed" : {
      "comment" : "Benefit of always-on location",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Инструментите работят, дори когато приложението е затворено"
          }
        }
      }
    },
    "You can disable reminders anytime in Settings." : {
      "comment" : "Reassurance note on the notification permission screen.",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Можете да изключите напомнянията по всяко време от Настройки."
          }
        }
      }
    },
    "You'll be notified when you're near a saved card location" : {
      "comment" : "Status text when nearby notifications are active",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ще бъдете уведомени, когато сте близо до запазено местоположение"
          }
        }
      }
    },
    "You're near %lld saved locations" : {
      "comment" : "Notification title when near multiple card locations",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вие сте близо до %lld запазени местоположения"
          }
        }
      }
    },
    "You're near a saved location" : {
      "comment" : "Notification title when near a single card location",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вие сте близо до запазено местоположение"
          }
        }
      }
    },
    "Your cards stay on this device by default. If iCloud is enabled, they also sync through your private iCloud database." : {
      "comment" : "Privacy policy explanation of data storage",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вашите карти остават на вашето устройство по подразбиране. Ако имате настроен достъп до iCloud, те също така ще бъдат синхронизирани с личният ви iCloud."
          }
        }
      }
    },
    "Your cards, always ready" : {
      "comment" : "Title on first-launch empty card list",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Картите ви, винаги готови"
          }
        }
      }
    },
    "Your location is only used to calculate distance to saved stores." : {
      "comment" : "Privacy reassurance on the location permission screen.",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Местоположението ви се използва само за изчисляване на разстояние до запазени магазини."
          }
        }
      }
    },
    "Your location is only used to find nearby stores" : {
      "comment" : "Privacy assurance about location data usage",
      "localizations" : {
        "bg" : {
